# Force LF line endings for all text files
* text=auto eol=lf

# Go source files
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Shell scripts
*.sh text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Markdown files
*.md text eol=lf

# Configuration files
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.exe binary
*.so binary
*.dylib binary
